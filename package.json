{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@oliversalzburg/js-utils",
  "version": "0.6.0",
  "license": "MIT",
  "author": "Oliver Salzburg <oliver.salzburg@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oliversalzburg/js-utils.git"
  },
  "type": "module",
  "exports": {
    "./*.js": {
      "types": "./lib/*.d.ts",
      "default": "./lib/*.js"
    }
  },
  "files": [
    "./lib/**/*.d.ts",
    "./lib/**/*.js",
    "./lib/**/*.map"
  ],
  "scripts": {
    "preversion": "make lint test",
    "postversion": "git push"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "24.10.13",
    "@types/web": "0.0.338",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
